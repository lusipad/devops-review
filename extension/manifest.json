{
  "manifest_version": 3,
  "name": "Azure DevOps Codex Review",
  "version": "0.2.1",
  "description": "Ask Codex about selected Azure DevOps PR code using the complete local repository.",
  "key": "",
  "permissions": [
    "nativeMessaging",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Azure DevOps Codex Review"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "options_page": "options.html"
}
